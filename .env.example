# --- DJANGO ---
DJANGO_SECRET_KEY=django-insecure-p6^ped7h!8lxdm0f7pw%u0p!$h--b6lpi7aae5eli4(g)a+u@6
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# --- DATABASE (Docker) ---
# Schema isolado `notification` dentro do banco compartilhado `atlas`.
POSTGRES_DB=atlas_notification
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=atlas_password
DATABASE_URL=postgres://atlas_user:atlas_password@db:5432/atlas_notification

# --- Comunicação interna entre serviços ---
# Segredo compartilhado exigido no header X-Internal-Token para criar
# notificações a partir de outros serviços (auth, scholarship, tracks...).
INTERNAL_TOKEN=troque_este_token_interno

# --- Listagem ---
# Janela (dias) que oculta notificações JÁ LIDAS; as não lidas nunca somem.
NOTIFICATION_LIST_WINDOW_DAYS=5

# --- JWT (opcional) ---
# Por padrão o token é assinado/validado com a DJANGO_SECRET_KEY. Para usar um
# segredo dedicado só ao JWT, defina o MESMO valor aqui, no auth-service e em
# todos os serviços que validam (track, scholarship). Deixe vazio para manter
# o comportamento atual.
# JWT_SIGNING_KEY=
